# OpenAI API Key for AI-powered coaching
OPENAI_API_KEY=your-api-key

# Optional: Model to use (default: gpt-5-mini)
OPENAI_MODEL=gpt-5-mini

# ============ Security Configuration ============

# API Secret Key (optional - if set, all API endpoints require X-API-Key header)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_SECRET_KEY=your-secret-key-here

# Allowed CORS origins (comma-separated, default: localhost only)
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Rate limits (default: 10/minute for AI, 60/minute for validation)
RATE_LIMIT_AI=10/minute
RATE_LIMIT_VALIDATION=60/minute

# ============ Frontend Configuration ============

# Backend API URL (for Streamlit frontend)
API_BASE_URL=http://localhost:8000
