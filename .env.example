# ============ OpenAI Configuration ============
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# ============ Security Configuration ============
# API Secret Key – generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Environment: "development" or "production"
PYTHON_ENV=development

# ============ Database ============
# PostgreSQL: postgresql://user:password@host:5432/dbname
# SQLite (dev): sqlite:///./vpc_dev.db
DATABASE_URL=sqlite:///./vpc_dev.db

# ============ Rate Limits ============
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_REGISTER=3/hour
RATE_LIMIT_AI=10/minute
RATE_LIMIT_VALIDATION=60/minute
RATE_LIMIT_CANVAS=60/minute
RATE_LIMIT_ADMIN=30/minute

# ============ Session ============
SESSION_EXPIRY_HOURS=24

# ============ Frontend ============
API_BASE_URL=http://localhost:8000
